# ── LLM Providers (required) ──────────────────────────────────────────────────
# Groq: Llama models (extraction, hiring signals, sentiment)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter: Claude models (pre-filter, validation, synthesis, conversational)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Embeddings (optional — only needed if embedder is called) ──────────────────
# Leave blank if you don't have an embedding provider yet.
# Options:
#   1. Set OPENAI_API_KEY (uses OpenAI text-embedding-3-small)
#   2. Set EMBEDDING_BASE_URL + EMBEDDING_API_KEY for any OpenAI-compat endpoint
OPENAI_API_KEY=
EMBEDDING_BASE_URL=

# ── Deprecated (no longer called directly — use OpenRouter above) ──────────────
# ANTHROPIC_API_KEY=

# ── Web Crawling / Search ──────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Storage ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=market_intelligence

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

REDIS_URL=redis://localhost:6379

# ── Observability ──────────────────────────────────────────────────────────────
# Langfuse (optional for local smoke testing — set enabled=False in init_tracing)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development

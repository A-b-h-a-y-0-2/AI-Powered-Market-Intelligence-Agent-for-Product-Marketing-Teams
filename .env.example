# ── LLM Providers (required) ──────────────────────────────────────────────────
# Groq: Llama models (extraction, hiring signals, sentiment)
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter: Claude models (pre-filter, validation, synthesis, conversational)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Embeddings (optional — only needed if embedder is called) ──────────────────
# Leave blank if you don't have an embedding provider yet.
# Options:
#   1. Set OPENAI_API_KEY (uses OpenAI text-embedding-3-small)
#   2. Set EMBEDDING_BASE_URL + EMBEDDING_API_KEY for any OpenAI-compat endpoint
OPENAI_API_KEY=
EMBEDDING_BASE_URL=

# ── Deprecated (no longer called directly — use OpenRouter above) ──────────────
# ANTHROPIC_API_KEY=

# ── Web Crawling / Search ──────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
APIFY_API_KEY=your_apify_api_key_here

# ── Data Sources (all free-tier / registration-only) ──────────────────────────

# UK Companies House — register at https://developer.company-information.service.gov.uk/
# Why: revenue/director data for McKinsey, BCG, Bain UK subsidiaries (private firms must file here)
COMPANIES_HOUSE_API_KEY=

# Lens.org — register at https://www.lens.org/lens/user/subscriptions
# Why: global patent filings — 12-24 month leading indicator of R&D direction
LENS_API_KEY=

# CourtListener — optional, register at https://www.courtlistener.com/sign-in/
# Why: 30k req/day (vs 5k unauth) — federal litigation signals
COURT_LISTENER_TOKEN=

# GitHub — generate at https://github.com/settings/tokens (no scopes required)
# Why: 5000 req/hour (vs 60 unauth) for AccentureOpenSource / BCG-X-official monitoring
GITHUB_TOKEN=

# Alpha Vantage — register at https://www.alphavantage.co/support/#api-key
# Why: Accenture (ACN) stock news + pre-computed sentiment (25 req/day free)
ALPHA_VANTAGE_API_KEY=

# OpenSecrets — register at https://www.opensecrets.org/api/admin/
# Why: federal lobbying disclosures for Accenture, Deloitte, KPMG (200 req/day)
OPEN_SECRETS_API_KEY=

# ── Storage ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=market_intelligence

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

REDIS_URL=redis://localhost:6379

# ── Observability ──────────────────────────────────────────────────────────────
# Langfuse (optional for local smoke testing — set enabled=False in init_tracing)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development
